{
  "name": "wavelytics",
  "private": true,
  "version": "0.1.0",
  "description": "Wavelytics — Operations & Compliance Intelligence platform",
  "workspaces": ["web", "server"],
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "npm --workspace web run dev",
    "dev:server": "npm --workspace server run dev",
    "build": "npm --workspace web run build",
    "start": "npm --workspace server run start",
    "seed": "npm --workspace server run seed"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
