# Wavelytics environment configuration
# ---------------------------------------------------------------------------
# SERVER (API)  — copy to server/.env for local dev, or set in Render.
# ---------------------------------------------------------------------------

# Leave DATABASE_URL unset to run on the built-in simulated feed (no DB needed).
# Set it to a Postgres connection string (Supabase, Neon, Railway, local) to
# persist and serve real metrics.
# Supabase: Project Settings → Database → Connection string → URI (use the
# "Connection pooling" / port 6543 string for serverless-friendly pooling).
# DATABASE_URL=postgres://user:password@host:5432/wavelytics

# API port (Render sets PORT automatically; local default is 4000).
PORT=4000

# CORS: the web origin(s) allowed to call this API in production.
# Comma-separate multiple (e.g. prod + a Vercel preview domain).
# Leave unset for local dev / open demo (allows all origins).
# CORS_ORIGIN=https://wavelytics.vercel.app

# Supabase Auth: enables logins, per-tenant data, and CSV uploads.
# Find it in Supabase → Project Settings → API → "JWT Secret".
# Leave unset to run the open, simulated public demo with no logins.
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ---------------------------------------------------------------------------
# WEB (frontend) — set in Vercel as a build-time env var (must be VITE_ prefixed).
# ---------------------------------------------------------------------------

# Base URL of the deployed API. Leave unset for local dev (Vite proxies /api
# to localhost:4000). In production point it at the Render API URL.
# VITE_API_URL=https://wavelytics-api.onrender.com

# Supabase Auth for the browser (enables the Sign in / Upload UI).
# Supabase → Project Settings → API → "Project URL" and the "anon public" key.
# Leave both unset to ship the open, simulated public demo.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-public-key
