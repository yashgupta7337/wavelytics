# Wavelytics environment configuration
# Copy this file to server/.env and fill in real values to enable Postgres.

# Leave DATABASE_URL unset to run on the built-in simulated feed (no DB needed).
# Set it to a Postgres connection string (Neon, Supabase, Railway, local) to
# persist and serve real metrics.
# DATABASE_URL=postgres://user:password@host:5432/wavelytics

# API port
PORT=4000
